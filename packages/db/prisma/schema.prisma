// Town-Next persistence.
//
// We store CORE OAuth2 access/refresh tokens server-side and hand the browser
// only an opaque session id cookie. Every CORE API call goes through a
// Next.js Route Handler that looks up the token by session id and calls
// app.getcore.me with `Authorization: Bearer <token>`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A signed-in town visitor. `coreUserId` is the `sub` returned by CORE's
// /oauth/userinfo — the stable identity across re-logins and email changes.
model User {
  id          String   @id @default(cuid())
  // CORE OAuth `sub`. No longer unique by itself; identity is the
  // composite (coreUserId, workspaceId). The same CORE user signing
  // into a different workspace produces a fresh User row.
  coreUserId  String
  email       String
  name        String
  // CORE workspace this account belongs to. Nullable only for
  // pre-migration rows; the OAuth callback fills it in on next
  // login via the one-shot grace path.
  workspaceId String?
  // Sprite key the user appears as in any town they visit. Owner picks
  // this at onboarding (defaults to the postman). One of the keys defined
  // in @/lib/characters.ts.
  character   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions             Session[]
  townEvents           TownEventRow[]
  integrations         IntegrationRow[]
  aspects              AspectRow[]
  labels               LabelRow[]
  towns                Town[]
  suggestions          PlotSuggestion[]
  sprites              Sprite[]
  creatorConversations CreatorConversation[]
  tokenUsage           TokenUsage[]

  @@unique([coreUserId, workspaceId])
  @@index([email])
}

// A user's public, shareable town. The slug is the URL segment (e.g.
// /harshith) and the share code gates non-owner visitors. A user can own
// multiple towns; the town's workspace is implicit via owner.workspaceId.
model Town {
  id            String         @id @default(cuid())
  slug          String         @unique
  // Human-readable name the owner picked at onboarding. Displayed on the
  // visitor gate ("You're about to enter Harshith's Town") and used as the
  // default panel title.
  name          String
  // Optional one-paragraph pitch shown in the welcome dialogue the first
  // time a visitor loads the town. Deployed from `town.json` — null when
  // the owner hasn't authored one, in which case the welcome dialogue
  // stays quiet.
  description   String?
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // 6-char base32 code rotated via the Share modal's Reset button.
  // Visitors must present this once; we then drop a per-slug cookie so
  // they don't have to re-enter on subsequent visits.
  shareCode     String         @unique

  // Town lifecycle. "active" is the published, visitor-accessible state
  // (default). "draft" hides the town from non-owners until the owner
  // first deploys. "renovating" is set transiently during /api/town?from=creator
  // applies so the renderer can show a brief overlay; flipped back to
  // "active" inside the same transaction that applies the shape.
  status        String         @default("active")

  // Owner opt-in to appear on the public /explore leaderboard. When true
  // the /explore page lists this town and embeds a share-code-prefilled
  // link so anyone can enter without knowing the code up front. When
  // false the town behaves exactly as before — only reachable via the
  // owner sharing the code manually.
  isPublic      Boolean        @default(false)

  // Pending mutation queue for this town. Each entry mirrors a tool
  // call the creator agent made:
  //   { id, kind, payload, summary, createdAt }
  // Stored at the Town level (not the conversation level) so the queue
  // persists across `/clear` and CLI restarts. Only an explicit Clear
  // or Approve from the user — or remove_pending_change from the agent —
  // drops entries.
  pendingChanges Json          @default("[]")

  aura                 Aura?
  plot                 PlotRow?
  npcs                 Npc[]
  conversations        Conversation[]
  suggestions          PlotSuggestion[]
  creatorConversations CreatorConversation[]
  tokenUsage           TokenUsage[]
  visits               TownVisit[]
  // Per-town catalog of visitor tags + SVG item templates. Authored under
  // the town deployment directory (tags inline in town.json, items as
  // items/manifest.json + items/<id>.svg) and uploaded via /api/town.
  // Shape mirrors TownCatalog from @town/types: { tags, items: [...{svg}] }.
  // Null = the town has no catalog → grant_tag / give_item NPC tools won't
  // register for any NPC in this town.
  catalogJson   Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([ownerId])
}

// A pairwise chat between two players inside one town. Participants are
// identified by a stable "key" string:
//   • "user:<userId>"   — signed-in player
//   • "guest:<guestId>" — unsigned visitor, key kept in the visitor cookie
//
// `aKey` < `bKey` always (string-sorted) so the composite unique index
// works regardless of who messages first.
//
// Only the two participants ever read these rows. The town owner has no
// special read access — the API gates lookup on `aKey ∈ {viewer}`.
model Conversation {
  id             String    @id @default(cuid())
  townId         String
  town           Town      @relation(fields: [townId], references: [id], onDelete: Cascade)
  aKey           String
  bKey           String
  lastMessageAt  DateTime  @default(now())
  // When non-null, points at the most recent message that hasn't been
  // answered by the *other* party. The proximity-pill UI uses this to
  // know whose head the "needs reply" indicator should hover above.
  pendingFromKey String?
  createdAt      DateTime  @default(now())
  messages       Message[]

  @@unique([townId, aKey, bKey])
  @@index([townId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromKey        String
  text           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// One row per active sign-in. The browser cookie holds `id` (opaque).
// `accessToken` is what we use to call CORE; `refreshToken` lets us mint a
// new access token without re-prompting the user. Both stay server-side.
model Session {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken    String
  refreshToken   String?
  // When the access token expires. We refresh lazily when it's within ~60s of
  // expiry rather than running a background job.
  tokenExpiresAt DateTime
  // When the session itself expires (cookie + row both get torn down).
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Short-lived row covering one in-flight OAuth handshake. We need to remember
// the PKCE code_verifier and the random `state` between the redirect to
// app.getcore.me and the callback. Rows older than 10 minutes are stale and
// can be GC'd by the next callback.
model OAuthState {
  state         String   @id
  codeVerifier  String
  // Where to send the user after a successful login (defaults to "/").
  redirectAfter String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([expiresAt])
}

// Per-user Plot — the source of truth for what their town looks like.
// `json` is the full Plot from @town/plot. `version` increments on every
// write so the client can poll cheaply ("?since=N", server only sends the
// row when the stored version is higher).
//
// Bootstrap: when /api/plot GETs for a user without a row, we generate a
// seeded default (3 buildings: home, library, store) via @town/plot-gen
// and insert it. After that the row is the only source of truth — events
// + AI + manual edits all flow through writes here, and the renderer
// re-reads on every change.
model PlotRow {
  townId    String   @id
  town      Town     @relation(fields: [townId], references: [id], onDelete: Cascade)
  json      Json
  version   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Raw inbound event log. `id` is the envelope's ULID, used as an
// idempotency key (`isDuplicate` checks for an existing row). The payload
// is stored verbatim so we can replay history through the rules engine
// later if the rules change.
model TownEventRow {
  id          String    @id
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  occurredAt  DateTime
  payload     Json
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@index([userId, occurredAt])
  @@index([userId, type])
}

// Mirror of CORE's per-user integration connection state. The rules engine
// upserts on `integration.connected` and clears `disconnectedAt` on a
// reconnect; `integration.disconnected` stamps `disconnectedAt`.
model IntegrationRow {
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug           String
  category       String
  scopes         String[]
  connectedAt    DateTime
  disconnectedAt DateTime?

  @@id([userId, slug])
  @@index([userId])
}

// Mirror of CORE Label entities (the user's CORE-side label library).
// Labels aren't a TownEvent type — they're additive context for the
// curator. Bootstrap pulls them once via /api/v1/labels and stores them
// here for `buildUserProfile` to read. Unique on (userId, name) so
// re-running bootstrap is idempotent without us holding CORE's id.
model LabelRow {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // CORE's own label id when present — preserved for future de-dup
  // strategies but not required because (userId, name) is the gate.
  coreLabelId String?
  name        String
  color       String?
  kind        String?
  seenAt      DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

// Mirror of CORE Aspect entities. Keyed by CORE's aspect uuid so
// `aspect.invalidated` events can look up + supersede a row without us
// holding our own surrogate id.
model AspectRow {
  uuid          String    @id
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aspect        String
  fact          String
  validAt       DateTime
  invalidAt     DateTime?
  invalidatedBy String?

  @@index([userId, aspect])
  @@index([userId, invalidAt])
}

// Per-user NPC roster. Every building in a user's plot can host one or
// more NPCs the player can talk to. The DB row holds the durable knobs
// (name / description / system prompt) and the `town` CLI mirrors each
// row out to an .mdx file in the plot directory so editors can iterate.
//
// `buildingId` references PlotRow.json.buildings[].id but is not an FK
// (PlotRow.json is a JSON blob; the application enforces referential
// integrity at write time).
model Npc {
  id          String   @id @default(cuid())
  townId      String
  town        Town     @relation(fields: [townId], references: [id], onDelete: Cascade)
  buildingId  String
  // Slot within the building's variant — see `npcPositions` in @town/catalog
  // and @town/plot. Empty string is the implicit "first slot" that one-slot
  // variants resolve to, so existing rows stay valid without backfill.
  slotId      String   @default("")
  // Display name shown on the speaker line, e.g. "Hudson".
  name        String
  // Short flavor-text shown when the player approaches.
  description String
  // System prompt fed to the LLM when the player chats with this NPC.
  prompt      String
  // Capability grants — what CORE tools this NPC may invoke during chat.
  // Shape mirrors NpcPermissions in apps/web/src/lib/npc-templates.ts:
  //   { integrations: [{slug, actions?}], core: {tasks?, memory_search?},
  //     skills: {inject?, callable?} }
  // Null is treated as "no tools" — even memory_search must be granted.
  // seedNpcs() populates this from the MDX template; users can edit it
  // later for per-instance customisation.
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([townId])
  @@index([townId, buildingId])
  @@index([townId, buildingId, slotId])
}

// User-uploaded sprite (PNG bytes for a CustomPlot exterior / interior /
// prop). Content-addressed so repeat uploads of the same image are free.
// Served by /api/sprites/<contentHash>.png with immutable cache headers;
// the renderer hits that URL whenever a CustomPlot sprite ref is of the
// form "sprite:<contentHash>".
//
// Scope is per-user so deleting an account cleans up the bytes without
// affecting other towns; the (userId, contentHash) unique stops the
// same town from storing duplicates.
model Sprite {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentHash String
  // PNG payload. Postgres TOAST handles out-of-line storage for the
  // multi-KB range these end up at.
  bytes       Bytes
  width       Int
  height      Int
  byteSize    Int
  createdAt   DateTime @default(now())

  @@unique([userId, contentHash])
  @@index([userId])
}

// Queued plot/NPC change waiting for the player's approval. The events
// worker no longer mutates the plot directly — it converts each Effect
// from decide() into a PlotSuggestion row (status = "pending"). The
// player approves or declines from in-game; approval runs applyEffects
// for that single suggestion and marks the row resolved.
//
// `kind` mirrors the Effect discriminator from apps/web/src/lib/town/decide.ts:
//   "add-building"  payload: { plotKey, reason }           — also seeds 1 default NPC
//   "update-npc"    payload: { npcId, fields, reason }     — patch name/description/prompt
//   "add-npc"       payload: { buildingId, name, description, prompt, reason }
//
// `sourceEventId` points at the TownEventRow that produced this
// suggestion so we can trace back to the originating CORE event.
model PlotSuggestion {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  townId        String
  town          Town      @relation(fields: [townId], references: [id], onDelete: Cascade)
  kind          String
  status        String    @default("pending")
  payload       Json
  reason        String
  sourceEventId String?
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([townId, status])
}

// Per-house group chat message log. One row per posted message (human
// or NPC). `channelId` is the Centrifugo room channel — see
// features/group-chat/server/channel.ts (`roomChannel`) for the wire
// format; the same string keys live messages and the history backfill
// query.
//
// Authors:
//   • Human posts → authorKey = "user:<userId>" / "guest:<guestId>"
//     (same shape Conversation already uses), isNpc = false.
//   • NPC posts   → authorKey = "npc:<npcId>", isNpc = true.
//
// `topicId` is null for the always-on "#general" room and points at
// a GroupTopic when the message was posted inside a user-created
// topic. History rows for expired topics are filtered out at read
// time (types.ts HISTORY_WINDOW_MS + active-topic join).
//
// Retention: the history endpoint only ever returns rows from the
// last hour (HISTORY_WINDOW_MS in types.ts). Older rows are
// invisible to readers; a periodic sweeper can purge them later if
// storage matters — none for v1.
model GroupMessage {
  id         String   @id @default(cuid())
  channelId  String
  topicId    String?
  authorKey  String
  authorName String
  isNpc      Boolean  @default(false)
  text       String
  createdAt  DateTime @default(now())

  @@index([channelId, createdAt])
  @@index([channelId, topicId, createdAt])
}

// User-created ephemeral topic inside a building's group chat. Sits
// alongside the always-on "#general" (represented by topicId=null on
// GroupMessage). Every room caps at MAX_TOPICS_PER_BUILDING active
// topics and each user at MAX_TOPICS_PER_USER active topics per room
// — enforced in the create endpoint. `expiresAt` is a hard clock set
// to `createdAt + TOPIC_TTL_MS`; the cap counts unexpired rows only.
model GroupTopic {
  id            String   @id @default(cuid())
  channelId     String
  townSlug      String
  buildingId    String
  title         String
  createdByKey  String
  createdByName String
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  closedAt      DateTime?

  @@index([channelId, expiresAt])
  @@index([channelId, createdByKey, expiresAt])
}

// One row per (town, viewerKey) — a unique-visitor ledger for towns.
// `viewerKey` follows the same "user:<id>" / "guest:<id>" shape used by
// Conversation / VisitorTag. Written by /api/towns/[slug]/visit inside
// the same handler that sets the visitor cookie, so successful gate
// entry is the trigger. The unique constraint means repeat visits by
// the same viewer no-op the upsert, so `count(rows)` = distinct
// visitors — the input to the /explore leaderboard score.
model TownVisit {
  id         String   @id @default(cuid())
  townId     String
  town       Town     @relation(fields: [townId], references: [id], onDelete: Cascade)
  viewerKey  String
  createdAt  DateTime @default(now())

  @@unique([townId, viewerKey])
  @@index([townId])
}

// Tag awarded to a visitor by an NPC. Town-scoped (so the same browser can
// carry separate tag sets in personal towns vs. the public Core town).
// `subjectKey` follows the same "user:<id>" / "guest:<id>" shape as
// Conversation / GroupMessage so signed-in and anonymous visitors share
// one award model.
//
// `tagId` references an entry in apps/web/src/data/town-tags.ts — kept as
// a string (no FK) because the catalog lives in app code, not the DB.
// The unique on (townSlug, subjectKey, tagId) makes re-grants idempotent.
model VisitorTag {
  id           String    @id @default(cuid())
  townSlug     String
  subjectKey   String
  tagId        String
  awardedByNpc String?
  reason       String?
  // null = permanent. Expired rows stay on the row for audit and can be
  // filtered out at read time; a sweeper can purge later if storage matters.
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  @@unique([townSlug, subjectKey, tagId])
  @@index([townSlug, subjectKey])
}

// SVG-template item awarded to a visitor. Templates live as .svg files in
// apps/web/src/data/town-items/; `templateId` is the file basename minus
// the .svg extension. `fields` is the per-issue placeholder substitution
// blob (e.g. {defendant, charge, sentence} for verdict-card).
//
// One row per award — visitors can collect multiple verdict cards from
// multiple trials. The public share page reads by id.
model VisitorItem {
  id           String   @id @default(cuid())
  townSlug     String
  subjectKey   String
  templateId   String
  fields       Json
  awardedByNpc String?
  createdAt    DateTime @default(now())

  @@index([townSlug, subjectKey, createdAt])
  @@index([templateId, createdAt])
}

// Town-scoped activity feed. One row per surfaced event (visit, npc
// chat, tag/item award, group-chat session start). The FEED panel in
// /{slug} reads back the most recent rows newest-first.
//
// `subjectKey` is the same "user:<id>" / "guest:<id>" shape used by
// Conversation / VisitorTag — lets the same browser collect activity
// across signed-in and anonymous visits.
//
// `subjectName` + `subjectCharacter` are denormalized at write time so
// the feed doesn't need to join back to User on render and so a name
// change doesn't rewrite history.
//
// Dedupe is handled at write time inside recordTownActivity() — kinds
// like `visit` / `npc_chat` / `group_chat_started` only emit when no
// matching row exists in a per-kind lookback window.
model TownActivity {
  id               String   @id @default(cuid())
  townSlug         String
  kind             String
  subjectKey       String
  subjectName      String
  subjectCharacter String?
  metadata         Json
  createdAt        DateTime @default(now())

  @@index([townSlug, createdAt])
  @@index([townSlug, kind, subjectKey, createdAt])
}

// Per-town energy meter ("aura"). v1 stores just `current` and `max`;
// the follow-up ledger spec adds debit/top-up event rows on top.
// Created in the same transaction as the Town it belongs to so the
// invariant "every Town has an Aura row" holds at the DB level.
model Aura {
  townId    String   @id
  town      Town     @relation(fields: [townId], references: [id], onDelete: Cascade)
  current   Int      @default(1000)
  max       Int      @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-town, per-user chat thread for the AI town creator (the `town
// chat` flow). One conversation is "active" at a time per (town, user);
// `town chat --clear` flips it to "cleared" and opens a fresh row so the
// player's history is preserved for audit but invisible at run time.
//
// Disjoint from the existing visitor `Conversation` model on purpose —
// this is owner-only creator chat, not pairwise player chat.
model CreatorConversation {
  id        String   @id @default(cuid())
  townId    String
  town      Town     @relation(fields: [townId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "active" | "cleared". Only one row per (townId, userId) is "active"
  // at any time; the route handler upserts on first turn.
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages CreatorMessage[]

  @@index([townId, status])
  @@index([userId, status])
}

// Per-call LLM usage log. One row per completed AI-SDK call
// (streamText / generateObject / generateText). Written fire-and-forget
// from every LLM call site so the underlying response is never blocked
// on the insert.
//
// `townId` is the primary linkage: every LLM call in this app happens
// inside a town context (npc chat rooms, group chat rooms, creator CLI
// scoped to a town). `userId` is who the call is attributed to for
// quota/billing purposes — the town owner for chat surfaces, the
// caller for the creator CLI. `npcId` is set when the call produced
// an NPC turn (real Npc.id or system id like "core-founder"); null
// for user-driven calls (creator CLI) and for the moderator (which
// picks *which* NPC replies but doesn't itself speak).
//
// `event` values:
//   • single_chat          — 1:1 NPC chat (/api/npc-chat, /api/founder-chat)
//   • group_chat           — NPC reply inside a group room
//   • decision             — group-chat moderator picking who replies
//   • town_building_chat   — creator CLI chat (/api/creator)
//
// `buildingId` is populated when the call is scoped to a specific
// building; null for account-scoped calls (creator CLI, founder-chat).
//
// `metadata` carries free-form extras — { topicId?, moderatorReason? }
// — so we can slice usage later without a schema migration.
model TokenUsage {
  id           String   @id @default(cuid())
  townId       String
  town         Town     @relation(fields: [townId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  npcId        String?
  buildingId   String?
  event        String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([townId, createdAt])
  @@index([townId, event, createdAt])
  @@index([userId, createdAt])
  @@index([npcId, createdAt])
}

// One stored turn in a CreatorConversation. `content` is the full AI SDK
// message payload (parts array — text + tool-call + tool-result) so
// the route handler can rehydrate the conversation verbatim on the
// next streamText() call.
model CreatorMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   CreatorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String                                                                  // "user" | "assistant" | "system"
  content        Json
  createdAt      DateTime            @default(now())

  @@index([conversationId, createdAt])
}

