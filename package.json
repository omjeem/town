{
  "name": "town-next",
  "version": "0.1.3",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @town/db run db:generate",
    "db:migrate": "pnpm --filter @town/db run db:migrate",
    "db:deploy": "pnpm --filter @town/db run db:deploy",
    "db:studio": "pnpm --filter @town/db run db:studio",
    "plot:build-default": "pnpm --filter @town/plot-gen run build-default"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  }
}
