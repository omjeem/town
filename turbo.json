{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.example"],
  "globalEnv": [
    "DATABASE_URL",
    "CORE_OAUTH_BASE",
    "CORE_OAUTH_CLIENT_ID",
    "CORE_OAUTH_CLIENT_SECRET",
    "CORE_OAUTH_REDIRECT_URI",
    "NODE_ENV"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
