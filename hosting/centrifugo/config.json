{
  "client": {
    "allowed_origins": ["http://localhost:3000", "http://localhost:3001"]
  },
  "engine": {
    "type": "redis",
    "redis": {
      "address": ["redis://redis:6379"]
    }
  },
  "channel": {
    "without_namespace": {
      "allow_subscribe_for_anonymous": false,
      "allow_publish_for_client": false
    },
    "namespaces": [
      {
        "name": "positions",
        "presence": true,
        "allow_subscribe_for_client": true,
        "allow_publish_for_subscriber": true,
        "history_size": 0
      },
      {
        "name": "dm",
        "allow_subscribe_for_client": true,
        "allow_publish_for_client": false,
        "history_size": 50,
        "history_ttl": "24h"
      },
      {
        "name": "user",
        "allow_subscribe_for_client": true,
        "allow_publish_for_client": false,
        "history_size": 20,
        "history_ttl": "1h"
      },
      {
        "_comment": "Per-house group chat room. Backfill is served from Postgres (last hour of GroupMessage rows), so history_size stays 0 — don't bump it for symmetry with dm/user. Subscribe is token-gated by features/group-chat/server/history.ts.",
        "name": "room",
        "allow_subscribe_for_client": true,
        "allow_publish_for_client": false,
        "history_size": 0
      }
    ]
  }
}
