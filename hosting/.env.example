# hosting/.env — consumed by hosting/docker-compose.yml (variable
# interpolation only; these are NOT read by the app via process.env).
# Quick start:  cd hosting && cp .env.example .env  # then fill the blanks

# ─── Public host + image tag ───────────────────────────────────────────
# Your bare public hostname (no scheme), e.g. town.getcore.me. Caddy gets a
# Let's Encrypt cert for it and the app derives CORE_OAUTH_REDIRECT_URI /
# CENTRIFUGO_PUBLIC_URL from it.
PUBLIC_HOST=
# Published image tag to run (redplanethq/town:<tag>).
TOWN_VERSION=latest

# ─── Postgres ──────────────────────────────────────────────────────────
POSTGRES_DB=town
POSTGRES_USER=town
POSTGRES_PASSWORD=

# ─── CORE OAuth ────────────────────────────────────────────────────────
CORE_OAUTH_BASE=https://app.getcore.me
CORE_OAUTH_CLIENT_ID=
CORE_OAUTH_CLIENT_SECRET=

# ─── Webhook ───────────────────────────────────────────────────────────
TOWN_WEBHOOK_SECRET=

# ─── LLM (need at least one key; Anthropic preferred) ──────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Centrifugo (shared secrets between web + centrifugo containers) ───
CENTRIFUGO_API_KEY=
CENTRIFUGO_TOKEN_HMAC_SECRET=
