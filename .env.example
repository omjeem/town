# ─── Database (required) ───────────────────────────────────────────────
DATABASE_URL=postgresql://town:town@localhost:5432/town?schema=public

# ─── CORE OAuth (required for login) ───────────────────────────────────
# CORE_OAUTH_CLIENT_ID / SECRET come from POST /api/oauth/clients on
# app.getcore.me. The registered redirect URI must match CORE_OAUTH_REDIRECT_URI.
CORE_OAUTH_BASE=https://app.getcore.me
CORE_OAUTH_CLIENT_ID=
CORE_OAUTH_CLIENT_SECRET=
CORE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
CORE_OAUTH_SCOPE=profile,email,openid

# ─── Public URLs ───────────────────────────────────────────────────────
# Without these, login and share links fall back to the prod host
# (town.getcore.me) and you "log in and land on prod".
PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── LLM (need at least one key; Anthropic preferred) ──────────────────
# LLM_PROVIDER is auto-detected from whichever key is set; set it to force
# anthropic|openai. OPENAI_API_KEY also enables custom-plot image generation.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Queue / worker (Redis, required) ──────────────────────────────────
REDIS_URL=redis://localhost:6379
# Set to 1 to run the events worker separately (e.g. on serverless).
DISABLE_IN_PROCESS_WORKER=
EVENTS_WORKER_CONCURRENCY=4

# ─── Webhook receiver (required to POST /api/events) ───────────────────
TOWN_WEBHOOK_SECRET=

# ─── Realtime / Centrifugo (optional — unset = single-player dev) ──────
CENTRIFUGO_API_BASE=
CENTRIFUGO_API_KEY=
CENTRIFUGO_TOKEN_HMAC_SECRET=
CENTRIFUGO_PUBLIC_URL=
NEXT_PUBLIC_CENTRIFUGO_URL=

# ─── Creator extras (optional) ─────────────────────────────────────────
# CREATOR_PROVIDER: anthropic (default) | openai. CREATOR_MODEL defaults to
# claude-sonnet-4-5 (anthropic) / gpt-4o-mini (openai). TAVILY_API_KEY enables
# the creator's web-research tool.
CREATOR_PROVIDER=anthropic
CREATOR_MODEL=
TAVILY_API_KEY=
